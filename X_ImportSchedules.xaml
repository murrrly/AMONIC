<Page x:Class="AMONIC.ImportSchedules"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Импорт изменений расписания"
      Background="#F5F5F5">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="Импорт изменений расписания" 
                   FontSize="22" 
                   FontWeight="Bold"
                   FontFamily="{StaticResource PrimaryFont}"
                   Foreground="{StaticResource DarkBlueBrush}"
                   Margin="0,0,0,20"/>

        <Border Grid.Row="1" 
                Background="White" 
                CornerRadius="5"
                BorderBrush="#DDD" 
                BorderThickness="1"
                Padding="15"
                Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Выберите CSV файл с изменениями расписания" 
                           FontFamily="{StaticResource PrimaryFont}"
                           Margin="0,0,0,10"/>
                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="txtFilePath" Width="400" IsReadOnly="True" FontFamily="{StaticResource SecondaryFont}"/>
                    <Button x:Name="btnBrowse" Content="Обзор" Style="{StaticResource PrimaryButton}" Click="BtnBrowse_Click" Width="80" Margin="10,0,0,0"/>
                </StackPanel>
                <Button x:Name="btnImport" Content="Импортировать" Style="{StaticResource PrimaryButton}" Click="BtnImport_Click" Width="160" Margin="0,15,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" 
                Background="White" 
                CornerRadius="5"
                BorderBrush="#DDD" 
                BorderThickness="1"
                Padding="15"
                Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Результат импорта" 
                           FontFamily="{StaticResource PrimaryFont}"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>
                <TextBlock x:Name="txtResult" FontFamily="{StaticResource SecondaryFont}" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="3" 
                Background="White" 
                CornerRadius="5"
                BorderBrush="#DDD" 
                BorderThickness="1"
                Padding="15">
            <StackPanel>
                <TextBlock Text="Формат CSV файла (Schedules_V12.csv):" 
                           FontFamily="{StaticResource PrimaryFont}"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>
                <TextBlock Text="ACTION, DATE, TIME, FLIGHT_NUMBER, DEPARTURE_AIRPORT, ARRIVAL_AIRPORT, AIRCRAFT_CODE, ECONOMY_PRICE, CONFIRMED" 
                           FontFamily="{StaticResource SecondaryFont}"
                           FontSize="11"/>
                <TextBlock Text="Пример: ADD, 2024-01-15, 08:30, AM123, DOH, AUH, B737, 250, OK" 
                           FontFamily="{StaticResource SecondaryFont}"
                           FontSize="11"
                           Margin="0,5,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
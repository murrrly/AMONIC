<Page x:Class="AMONIC.UserActivity"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Моя активность"
      Background="#F5F5F5">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="История моих сессий" 
                   FontSize="22" 
                   FontWeight="Bold"
                   FontFamily="{StaticResource PrimaryFont}"
                   Foreground="{StaticResource DarkBlueBrush}"
                   Margin="0,0,0,20"/>

        <DataGrid x:Name="dgSessions" 
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  RowBackground="White"
                  FontFamily="{StaticResource SecondaryFont}"
                  BorderBrush="#DDD"
                  RowHeight="35">

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasCrash}" Value="True">
                            <Setter Property="Background" Value="#FFE6E6"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Дата входа" Binding="{Binding LoginTime}" Width="180"/>
                <DataGridTextColumn Header="Дата выхода" Binding="{Binding LogoutTime}" Width="180"/>
                <DataGridTextColumn Header="Время в системе" Binding="{Binding Duration}" Width="120"/>
                <DataGridTextColumn Header="Причина аварии" Binding="{Binding CrashReason}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
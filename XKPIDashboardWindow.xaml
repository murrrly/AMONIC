<Window x:Class="AMONIC.KPIDashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KPI - Краткий обзор"
        Height="650" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5">

	<Grid Margin="20">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
			<TextBlock Text="KPI - Краткий обзор деятельности" 
                       FontSize="22" 
                       FontWeight="Bold"
                       FontFamily="{StaticResource PrimaryFont}"
                       Foreground="{StaticResource DarkBlueBrush}"/>
			<TextBlock x:Name="txtGenerationTime" FontSize="12" Foreground="Gray" VerticalAlignment="Bottom" Margin="20,0,0,0"/>
		</StackPanel>

		<ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="500">
			<StackPanel>
				<Border Background="White" CornerRadius="5" BorderBrush="#DDD" BorderThickness="1" Padding="15" Margin="0,0,0,15">
					<StackPanel>
						<TextBlock Text="Рейсы за 30 дней" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="150"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>
							<TextBlock Text="Подтверждённые:" FontFamily="{StaticResource SecondaryFont}" Grid.Row="0" Grid.Column="0"/>
							<TextBlock x:Name="txtConfirmedFlights" Grid.Row="0" Grid.Column="1" FontWeight="Bold" Foreground="Green"/>
							<TextBlock Text="Отменённые:" FontFamily="{StaticResource SecondaryFont}" Grid.Column="0" Margin="0,13,0,-8"/>
							<TextBlock x:Name="txtCancelledFlights" Grid.Row="1" Grid.Column="1" Margin="0,5,0,0" FontWeight="Bold" Foreground="Red"/>
						</Grid>
					</StackPanel>
				</Border>

				<Border Background="White" CornerRadius="5" BorderBrush="#DDD" BorderThickness="1" Padding="15" Margin="0,0,0,15">
					<StackPanel>
						<TextBlock Text="Загрузка рейсов за 30 дней" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="150"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>
							<TextBlock Text="Самый занятый день:" FontFamily="{StaticResource SecondaryFont}" Grid.Row="0" Grid.Column="0"/>
							<TextBlock x:Name="txtBusiestDay" Grid.Row="0" Grid.Column="1"/>
							<TextBlock Text="Самый свободный день:" FontFamily="{StaticResource SecondaryFont}" Grid.Column="0" Margin="-2,13,2,-8"/>
							<TextBlock x:Name="txtQuietestDay" Grid.Row="1" Grid.Column="1" Margin="0,5,0,0"/>
						</Grid>
					</StackPanel>
				</Border>

				<Border Background="White" CornerRadius="5" BorderBrush="#DDD" BorderThickness="1" Padding="15" Margin="0,0,0,15">
					<StackPanel>
						<TextBlock Text="Топ пассажиров за 30 дней" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
						<TextBlock x:Name="txtTop1" FontFamily="{StaticResource SecondaryFont}"/>
						<TextBlock x:Name="txtTop2" FontFamily="{StaticResource SecondaryFont}" Margin="0,5,0,0"/>
						<TextBlock x:Name="txtTop3" FontFamily="{StaticResource SecondaryFont}" Margin="0,5,0,0"/>
					</StackPanel>
				</Border>

				<Border Background="White" CornerRadius="5" BorderBrush="#DDD" BorderThickness="1" Padding="15" Margin="0,0,0,15">
					<StackPanel>
						<TextBlock Text="Среднее время полёта в день" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
						<TextBlock x:Name="txtAvgFlightTime" FontFamily="{StaticResource SecondaryFont}"/>
					</StackPanel>
				</Border>

				<Border Background="White" CornerRadius="5" BorderBrush="#DDD" BorderThickness="1" Padding="15" Margin="0,0,0,15">
					<StackPanel>
						<TextBlock Text="Процент пустых мест (по неделям)" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="100"/>
								<ColumnDefinition Width="100"/>
								<ColumnDefinition Width="100"/>
							</Grid.ColumnDefinitions>
							<Border Grid.Column="0" Background="#196AA6" CornerRadius="3" Padding="5" Margin="2">
								<TextBlock x:Name="txtWeek1Empty" Text="0%" Foreground="White" HorizontalAlignment="Center"/>
							</Border>
							<Border Grid.Column="1" Background="#196AA6" CornerRadius="3" Padding="5" Margin="2">
								<TextBlock x:Name="txtWeek2Empty" Text="0%" Foreground="White" HorizontalAlignment="Center"/>
							</Border>
							<Border Grid.Column="2" Background="#196AA6" CornerRadius="3" Padding="5" Margin="2">
								<TextBlock x:Name="txtWeek3Empty" Text="0%" Foreground="White" HorizontalAlignment="Center"/>
							</Border>
						</Grid>
						<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
							<TextBlock Text="Неделя 3" FontSize="10" Margin="0,0,30,0"/>
							<TextBlock Text="Неделя 2" FontSize="10" Margin="0,0,30,0"/>
							<TextBlock Text="Неделя 1" FontSize="10"/>
						</StackPanel>
					</StackPanel>
				</Border>

				<Border Background="White" CornerRadius="5" BorderBrush="#DDD" BorderThickness="1" Padding="15" Margin="0,0,0,15">
					<StackPanel>
						<TextBlock Text="Топ офисов по продажам за 30 дней" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
						<TextBlock x:Name="txtOffice1" FontFamily="{StaticResource SecondaryFont}"/>
						<TextBlock x:Name="txtOffice2" FontFamily="{StaticResource SecondaryFont}" Margin="0,5,0,0"/>
						<TextBlock x:Name="txtOffice3" FontFamily="{StaticResource SecondaryFont}" Margin="0,5,0,0"/>
					</StackPanel>
				</Border>

				<Border Background="White" CornerRadius="5" BorderBrush="#DDD" BorderThickness="1" Padding="15" Margin="0,0,0,15">
					<StackPanel>
						<TextBlock Text="Доход от продажи билетов" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="100"/>
								<ColumnDefinition Width="100"/>
								<ColumnDefinition Width="100"/>
							</Grid.ColumnDefinitions>
							<TextBlock Grid.Column="0" Text="Сегодня" FontWeight="Bold"/>
							<TextBlock Grid.Column="1" Text="Вчера" FontWeight="Bold" HorizontalAlignment="Center"/>
							<TextBlock Grid.Column="2" Text="Позавчера" FontWeight="Bold" HorizontalAlignment="Right"/>
							<TextBlock Grid.Row="1" Grid.Column="0" x:Name="txtTodayIncome" FontFamily="{StaticResource SecondaryFont}" Margin="0,5,0,0"/>
							<TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtYesterdayIncome" FontFamily="{StaticResource SecondaryFont}" Margin="0,5,0,0" HorizontalAlignment="Center"/>
							<TextBlock Grid.Row="1" Grid.Column="2" x:Name="txtTwoDaysAgoIncome" FontFamily="{StaticResource SecondaryFont}" Margin="0,5,0,0" HorizontalAlignment="Right"/>
						</Grid>
					</StackPanel>
				</Border>
			</StackPanel>
		</ScrollViewer>

		<StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
			<Button x:Name="btnClose" Content="Закрыть" Style="{StaticResource DangerButton}" Click="BtnClose_Click" Width="100"/>
		</StackPanel>
	</Grid>
</Window>
<Window x:Class="AMONIC.ChangeRoleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Изменение роли" 
        Height="250" Width="400"
        MinHeight="250" MinWidth="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="White">

    <Border Margin="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.ColumnSpan="2" 
                       Text="Изменение роли пользователя" 
                       FontSize="16" FontWeight="Bold"
                       FontFamily="{StaticResource PrimaryFont}"
                       Foreground="{StaticResource BrandBlueBrush}"
                       Margin="0,0,0,20"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Новая роль:" VerticalAlignment="Center"/>
            <ComboBox Grid.Row="1" Grid.Column="1" x:Name="cmbRole" DisplayMemberPath="Title" SelectedValuePath="ID"/>

            <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
				<Button Content="Отмена" Style="{StaticResource DangerButton}" Click="BtnCancel_Click" Width="100"/>
				<Button Content="Сохранить" Style="{StaticResource PrimaryButton}" Click="BtnSave_Click" Width="100" Margin="10,0,0,0"/>
			</StackPanel>
        </Grid>
    </Border>
</Window>
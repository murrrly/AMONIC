<Window x:Class="AMONIC.UserMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AMONIC Airlines. Окно пользователя" 
        Height="650" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

	<DockPanel>
		<Border DockPanel.Dock="Top" Background="{StaticResource BrandBlueBrush}" Height="50">
			<Grid>
				<StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="20,0">
					<TextBlock Text="AMONIC" Foreground="White" FontSize="18" FontWeight="Bold" FontFamily="{StaticResource PrimaryFont}"/>
					<TextBlock Text=" AIRLINES" Foreground="{StaticResource BrandOrangeBrush}" FontSize="18" FontWeight="Bold" FontFamily="{StaticResource PrimaryFont}"/>
				</StackPanel>

				<Menu HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0" Background="Transparent">
					<Menu.Resources>
						<Style TargetType="MenuItem">
							<Setter Property="Foreground" Value="{StaticResource DarkBlueBrush}"/>
							<Setter Property="FontFamily" Value="{StaticResource PrimaryFont}"/>
						</Style>
					</Menu.Resources>

					<MenuItem Header="Меню" Foreground="White" FontFamily="{StaticResource PrimaryFont}">
						<MenuItem Header="Поиск и бронирование" x:Name="mnuBooking" Click="MnuBooking_Click"/>
						<MenuItem Header="Моя активность" x:Name="mnuActivity" Click="MnuActivity_Click"/>
						<Separator/>
						<MenuItem Header="Выход" x:Name="mnuExit" Foreground="#E74C3C" Click="MnuExit_Click"/>
					</MenuItem>
				</Menu>
			</Grid>
		</Border>

		<Border DockPanel.Dock="Top" Background="{StaticResource DarkBlueBrush}" Padding="20">
			<StackPanel>
				<TextBlock x:Name="txtWelcome" FontSize="16" Foreground="White" FontFamily="{StaticResource PrimaryFont}"/>
				<StackPanel Orientation="Horizontal" Margin="0,10,0,0">
					<TextBlock Text="Time spent on system: " Foreground="#ECF0F1" FontSize="13" FontFamily="{StaticResource SecondaryFont}"/>
					<TextBlock x:Name="txtTimeSpent" Foreground="{StaticResource BrandOrangeBrush}" FontSize="13" FontWeight="Bold"/>
					<TextBlock Text=" | Crashes: " Foreground="#ECF0F1" FontSize="13" FontFamily="{StaticResource SecondaryFont}" Margin="20,0,0,0"/>
					<TextBlock x:Name="txtCrashes" Foreground="#E74C3C" FontSize="13" FontWeight="Bold"/>
				</StackPanel>
			</StackPanel>
		</Border>

		<Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"/>
	</DockPanel>
</Window>
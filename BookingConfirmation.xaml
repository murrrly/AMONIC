<Page x:Class="AMONIC.BookingConfirmation"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Подтверждение бронирования"
      Background="#F5F5F5">

	<Grid Margin="10">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<!-- Инфо о выбранных рейсах -->
			<RowDefinition Height="Auto"/>
			<!-- Форма добавления пассажира -->
			<RowDefinition Height="*"/>
			<!-- Список уже добавленных пассажиров -->
			<RowDefinition Height="Auto"/>
			<!-- Итог и кнопка Оплатить -->
		</Grid.RowDefinitions>

		<!-- Заголовок -->
		<TextBlock Grid.Row="0" 
                   Text="Оформление данных пассажиров" 
                   FontSize="22" 
                   FontWeight="Bold"
                   FontFamily="{StaticResource PrimaryFont}"
                   Foreground="{StaticResource DarkBlueBrush}"
                   Margin="0,0,0,20"/>

		<!-- Блок информации о выбранных рейсах -->
		<Border Grid.Row="1" Background="White" CornerRadius="5" BorderBrush="#DDD" BorderThickness="1" Padding="15" Margin="0,0,0,5">
			<StackPanel>
				<TextBlock Text="Выбранные авиарейсы:" FontSize="14" FontWeight="Bold" FontFamily="{StaticResource PrimaryFont}" Foreground="{StaticResource BrandBlueBrush}" Margin="0,0,0,10"/>
				<TextBlock x:Name="txtOutboundInfo" FontFamily="{StaticResource SecondaryFont}" Margin="5,2" TextWrapping="Wrap"/>
				<TextBlock x:Name="txtReturnInfo" FontFamily="{StaticResource SecondaryFont}" Margin="5,2" TextWrapping="Wrap" Visibility="Collapsed"/>
			</StackPanel>
		</Border>

		<!-- Панель ввода данных пассажира (Форма ФИЛЬТР-style) -->
		<Border Grid.Row="2" Background="White" CornerRadius="5" BorderBrush="#DDD" BorderThickness="1" Padding="15" Margin="0,0,0,5">
			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
				</Grid.RowDefinitions>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="130"/>
					<ColumnDefinition Width="1*"/>
					<ColumnDefinition Width="40"/>
					<ColumnDefinition Width="130"/>
					<ColumnDefinition Width="1*"/>
				</Grid.ColumnDefinitions>

				<TextBlock Grid.Row="0" Grid.ColumnSpan="5" Text="Информация о пассажире:" FontSize="14" FontWeight="Bold" FontFamily="{StaticResource PrimaryFont}" Foreground="{StaticResource BrandBlueBrush}" Margin="0,0,0,15"/>

				<!-- Левая колонка формы -->
				<TextBlock Grid.Row="1" Grid.Column="0" Text="Имя:" VerticalAlignment="Center" FontFamily="{StaticResource PrimaryFont}"/>
				<TextBox Grid.Row="1" Grid.Column="1" x:Name="txtFirstName" Margin="0,5" Height="26" VerticalContentAlignment="Center" FontFamily="{StaticResource SecondaryFont}"/>

				<TextBlock Grid.Row="2" Grid.Column="0" Text="Фамилия:" VerticalAlignment="Center" FontFamily="{StaticResource PrimaryFont}"/>
				<TextBox Grid.Row="2" Grid.Column="1" x:Name="txtLastName" Margin="0,5" Height="26" VerticalContentAlignment="Center" FontFamily="{StaticResource SecondaryFont}"/>

				<TextBlock Grid.Row="3" Grid.Column="0" Text="Дата рождения:" VerticalAlignment="Center" FontFamily="{StaticResource PrimaryFont}"/>
				<DatePicker Grid.Row="3" Grid.Column="1" x:Name="dpBirthdate" Margin="0,5" Height="26" FontFamily="{StaticResource SecondaryFont}"/>

				<!-- Правая колонка формы -->
				<TextBlock Grid.Row="1" Grid.Column="3" Text="Номер паспорта:" VerticalAlignment="Center" FontFamily="{StaticResource PrimaryFont}"/>
				<TextBox Grid.Row="1" Grid.Column="4" x:Name="txtPassportNumber" Margin="0,5" Height="26" VerticalContentAlignment="Center" FontFamily="{StaticResource SecondaryFont}"/>

				<TextBlock Grid.Row="2" Grid.Column="3" Text="Гражданство:" VerticalAlignment="Center" FontFamily="{StaticResource PrimaryFont}"/>
				<ComboBox Grid.Row="2" Grid.Column="4" x:Name="cmbCountry" DisplayMemberPath="Name" SelectedValuePath="ID" Margin="0,5" Height="26" FontFamily="{StaticResource SecondaryFont}"/>

				<TextBlock Grid.Row="3" Grid.Column="3" Text="Телефон:" VerticalAlignment="Center" FontFamily="{StaticResource PrimaryFont}"/>
				<TextBox Grid.Row="3" Grid.Column="4" x:Name="txtPhone" Margin="0,5" Height="26" VerticalContentAlignment="Center" FontFamily="{StaticResource SecondaryFont}"/>

				<!-- Кнопка добавления в таблицу (По центру снизу формы) -->
				<Button Grid.Row="4" Grid.ColumnSpan="5" Content="+ Добавить пассажира" Style="{StaticResource PrimaryButton}" Click="BtnAddPassenger_Click" Width="240" Height="32" Margin="0,15,0,0" HorizontalAlignment="Center"/>
			</Grid>
		</Border>

		<!-- Список добавленных пассажиров -->
		<DataGrid x:Name="dgPassengers" 
                  Grid.Row="3"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  RowBackground="White"
                  FontFamily="{StaticResource SecondaryFont}"
                  BorderBrush="#DDD"
                  RowHeight="35"
                  Margin="0,0,0,5">
			<DataGrid.Columns>
				<DataGridTextColumn Header="Имя" Binding="{Binding FirstName}" Width="120"/>
				<DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}" Width="120"/>
				<DataGridTextColumn Header="Дата рождения" Binding="{Binding Birthdate}" Width="120"/>
				<DataGridTextColumn Header="Паспорт" Binding="{Binding PassportNumber}" Width="130"/>
				<DataGridTextColumn Header="Гражданство" Binding="{Binding CountryName}" Width="150"/>
				<DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="*"/>
			</DataGrid.Columns>
		</DataGrid>

		<!-- Нижняя итоговая панель -->
		<Border Grid.Row="4" Background="White" CornerRadius="5" BorderBrush="#DDD" BorderThickness="1" Padding="15">
			<Grid>
				<StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
					<TextBlock Text="Добавлено пассажиров:" VerticalAlignment="Center" FontFamily="{StaticResource PrimaryFont}" Margin="0,0,10,0"/>
					<TextBlock x:Name="txtPassengerCount" Text="0 из 1" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" FontFamily="{StaticResource SecondaryFont}"/>
				</StackPanel>

				<StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
					<Button x:Name="btnBack" Content="← Назад" Style="{StaticResource DangerButton}" Background="#D9534F" Foreground="White" Click="BtnBack_Click" Width="100" Height="32"/>
					<Button x:Name="btnConfirm" Content="Перейти к оплате" Style="{StaticResource PrimaryButton}" Click="BtnConfirm_Click" Width="200" Height="32" Margin="15,0,0,0"/>
				</StackPanel>
			</Grid>
		</Border>
	</Grid>
</Page>
<Window x:Class="AMONIC.EditScheduleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование рейса" 
        Height="350" Width="450"
        MinHeight="350" MinWidth="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="White">

    <Border Margin="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.ColumnSpan="2" 
                       Text="Редактирование рейса" 
                       FontSize="18" FontWeight="Bold"
                       FontFamily="{StaticResource PrimaryFont}"
                       Foreground="{StaticResource BrandBlueBrush}"
                       Margin="0,0,0,20"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Дата:" VerticalAlignment="Center" FontFamily="{StaticResource PrimaryFont}"/>
            <DatePicker Grid.Row="1" Grid.Column="1" x:Name="dpDate" Margin="0,5" FontFamily="{StaticResource SecondaryFont}"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Время:" VerticalAlignment="Center" FontFamily="{StaticResource PrimaryFont}"/>
            <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtTime" Margin="0,5" FontFamily="{StaticResource SecondaryFont}"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Цена эконом:" VerticalAlignment="Center" FontFamily="{StaticResource PrimaryFont}"/>
            <TextBox Grid.Row="3" Grid.Column="1" x:Name="txtEconomyPrice" Margin="0,5" FontFamily="{StaticResource SecondaryFont}"/>

            <TextBlock Grid.Row="4" Grid.ColumnSpan="2" x:Name="txtError" Foreground="#E74C3C" Visibility="Collapsed" Margin="0,10"/>

            <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
				<Button Content="Отмена" Style="{StaticResource DangerButton}" Click="BtnCancel_Click" Width="100"/>
				<Button Content="Сохранить" Style="{StaticResource PrimaryButton}" Click="BtnSave_Click" Width="100" Margin="10,0,0,0"/>
			</StackPanel>
        </Grid>
    </Border>
</Window>
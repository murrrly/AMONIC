<Page x:Class="AMONIC.UsersManagement"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Управление пользователями"
      Background="#F5F5F5">

	<Grid Margin="20">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<TextBlock Grid.Row="0" 
                   Text="Управление пользователями системы" 
                   FontSize="22" 
                   FontWeight="Bold"
                   FontFamily="{StaticResource PrimaryFont}"
                   Foreground="{StaticResource DarkBlueBrush}"
                   Margin="0,0,0,20"/>

		<Border Grid.Row="1" 
                Background="White" 
                CornerRadius="5"
                BorderBrush="#DDD" 
                BorderThickness="1"
                Padding="15"
                Margin="0,0,0,15">
			<Grid>
				<Button x:Name="btnAddUser" 
                        Content="Добавить пользователя" 
                        Style="{StaticResource PrimaryButton}"
                        Click="BtnAddUser_Click"
                        HorizontalAlignment="Left"/>

				<Button x:Name="btnExit" 
                        Content="Выход" 
                        Style="{StaticResource PrimaryButton}"
                        Background="#D9534F" 
                        Foreground="White"
                        HorizontalAlignment="Right"
                        Click="BtnExit_Click"/>
			</Grid>
		</Border>

		<Border Grid.Row="2" 
                Background="White" 
                CornerRadius="5"
                BorderBrush="#DDD" 
                BorderThickness="1"
                Padding="15"
                Margin="0,0,0,20">
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="200"/>
					<ColumnDefinition Width="*"/>
				</Grid.ColumnDefinitions>
				<TextBlock Grid.Column="0" Text="Фильтр по офису:" 
                           VerticalAlignment="Center"
                           FontFamily="{StaticResource PrimaryFont}"
                           Margin="0,0,10,0"/>
				<ComboBox Grid.Column="1" x:Name="cmbOfficeFilter" 
                          SelectionChanged="CmbOfficeFilter_SelectionChanged"
                          FontFamily="{StaticResource SecondaryFont}"/>
			</Grid>
		</Border>

		<DataGrid x:Name="dgUsers" 
                  Grid.Row="3"
                  AutoGenerateColumns="False"
                  SelectionMode="Single"
                  IsReadOnly="True"
                  FontFamily="{StaticResource SecondaryFont}"
                  BorderBrush="#DDD"
                  RowHeight="35">

			<DataGrid.RowStyle>
				<Style TargetType="DataGridRow">
					<Style.Triggers>
						<DataTrigger Binding="{Binding Active}" Value="True">
							<Setter Property="Background" Value="#E6FFE6"/>
							<Setter Property="Foreground" Value="#000000"/>
						</DataTrigger>
						<DataTrigger Binding="{Binding Active}" Value="False">
							<Setter Property="Background" Value="#FFE6E6"/>
							<Setter Property="Foreground" Value="#555555"/>
						</DataTrigger>
					</Style.Triggers>
				</Style>
			</DataGrid.RowStyle>

			<DataGrid.Columns>
				<DataGridTextColumn Header="Имя" Binding="{Binding FirstName}" Width="150"/>
				<DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}" Width="150"/>
				<DataGridTextColumn Header="Возраст" Binding="{Binding Age}" Width="80"/>
				<DataGridTextColumn Header="Роль" Binding="{Binding RoleTitle}" Width="130"/>
				<DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="220"/>
				<DataGridTextColumn Header="Офис" Binding="{Binding OfficeTitle}" Width="*"/>
			</DataGrid.Columns>
		</DataGrid>

		<Border Grid.Row="4" 
                Background="White" 
                CornerRadius="5"
                BorderBrush="#DDD" 
                BorderThickness="1"
                Padding="15"
                Margin="0,20,0,0">
			<StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
				<Button x:Name="btnBlockUser" 
                        Content="Блокировать|Разблокировать" 
                        Style="{StaticResource PrimaryButton}"
                        Click="BtnBlockUser_Click"
                        Margin="0,0,10,0"/>

				<Button x:Name="btnChangeRole" 
                        Content="Изменить роль" 
                        Style="{StaticResource PrimaryButton}"
                        Click="BtnChangeRole_Click"
                        Margin="0,0,10,0"/>
			</StackPanel>
		</Border>
	</Grid>
</Page>
<Window x:Class="AMONIC.ImportSurveyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Импорт опросов" 
        Height="400" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White">

    <Border Margin="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" 
                       Text="Импорт опросов клиентов" 
                       FontSize="18" 
                       FontWeight="Bold"
                       FontFamily="{StaticResource PrimaryFont}"
                       Foreground="{StaticResource BrandBlueBrush}"
                       Margin="0,0,0,20"/>

            <TextBlock Grid.Row="1" Text="Выберите CSV файл с опросами:" FontFamily="{StaticResource PrimaryFont}" Margin="0,0,0,10"/>

            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,20">
                <TextBox x:Name="txtFilePath" Width="330" IsReadOnly="True" FontFamily="{StaticResource SecondaryFont}"/>
                <Button x:Name="btnBrowse" Content="Обзор" Style="{StaticResource PrimaryButton}" Click="BtnBrowse_Click" Width="80" Margin="10,0,0,0"/>
            </StackPanel>

            <Button Grid.Row="3" x:Name="btnImport" Content="Импортировать" Style="{StaticResource PrimaryButton}" Click="BtnImport_Click" Width="150" HorizontalAlignment="Left"/>

            <Border Grid.Row="4" Background="#F0F0F0" CornerRadius="5" Padding="10" Margin="0,20,0,0">
                <TextBlock Text="Формат CSV:\nGender, Age, DepartureAirport, ArrivalAirport, CabinType, Q1, Q2, Q3, Q4" 
                           FontSize="11" 
                           FontFamily="{StaticResource SecondaryFont}"
                           TextWrapping="Wrap"/>
            </Border>
        </Grid>
    </Border>
</Window>
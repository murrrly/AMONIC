<Window x:Class="AMONIC.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AMONIC Airlines. Авторизация" 
        Height="470" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
            
        <!-- Верхняя панель с логотипом -->
        <Image Grid.Row="0" Width="500"  Source="/DS2017_TP09_2_colors_with_bg.png" />

        <!-- Форма входа -->
        <Border Grid.Row="1" Margin="50,30,50,20">
            <Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
				</Grid.RowDefinitions>

				<TextBlock Grid.Row="0" 
                           Text="Email:" 
                           FontFamily="{StaticResource PrimaryFont}"
                           FontSize="14"
                           VerticalAlignment="Center"/>
                <TextBox Grid.Row="1" 
                         x:Name="txtEmail" 
                         Margin="0,10"
                         FontSize="14"
                         FontFamily="{StaticResource SecondaryFont}"/>

                <TextBlock Grid.Row="2" 
                           Text="Пароль:" 
                           FontFamily="{StaticResource PrimaryFont}"
                           FontSize="14"
                           VerticalAlignment="Center"/>
                <PasswordBox Grid.Row="3" 
                             x:Name="txtPassword" 
                             Margin="0,10"
                             FontSize="14"
                             FontFamily="{StaticResource SecondaryFont}"/>

                <TextBlock Grid.Row="4" Grid.ColumnSpan="2" 
                           x:Name="txtError" 
                           Foreground="#E74C3C" 
                           Visibility="Collapsed" 
                           TextWrapping="Wrap"
                           FontSize="12"
                           Margin="0,5"/>

                <TextBlock Grid.Row="3" Grid.ColumnSpan="2" 
                           x:Name="txtTimer" 
                           Foreground="{StaticResource BrandOrangeBrush}" 
                           Visibility="Collapsed" 
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           FontSize="13"
                           Margin="0,5"/>

                <StackPanel Grid.Row="4" Grid.ColumnSpan="2" 
                            Orientation="Horizontal" 
                            HorizontalAlignment="Center" 
                            Margin="0,20,0,0">
					<Button x:Name="btnCancel" 
                            Content="Отмена" 
                            Style="{StaticResource DangerButton}"
                            Click="BtnCancel_Click"/>
					<Button x:Name="btnLogin" 
                            Content="Вход" 
                            Style="{StaticResource PrimaryButton}"
                            Click="BtnLogin_Click"
                            Margin="10,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
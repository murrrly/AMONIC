<Window x:Class="AMONIC.PaymentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Оплата билетов" 
        Height="430" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White">

	<Border Margin="20">
		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
			</Grid.RowDefinitions>

			<TextBlock Grid.Row="0" 
                       Text="Оплата бронирования" 
                       FontSize="18" 
                       FontWeight="Bold"
                       FontFamily="{StaticResource PrimaryFont}"
                       Foreground="{StaticResource BrandBlueBrush}"
                       Margin="0,0,0,20"/>

			<Border Grid.Row="1" 
                    Background="#F0F0F0" 
                    CornerRadius="5"
                    Padding="15"
                    Margin="0,0,0,20">
				<StackPanel>
					<TextBlock Text="Итоговая сумма к оплате" 
                               FontFamily="{StaticResource PrimaryFont}"
                               FontSize="14"/>
					<TextBlock x:Name="txtTotalAmount" 
                               FontSize="28" 
                               FontWeight="Bold"
                               Foreground="{StaticResource BrandOrangeBrush}"
                               FontFamily="{StaticResource PrimaryFont}"/>
				</StackPanel>
			</Border>

			<TextBlock Grid.Row="2" Text="Способ оплаты:" FontFamily="{StaticResource PrimaryFont}" Margin="0,0,0,5"/>
			<StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,15">
				<RadioButton x:Name="rbCreditCard" Content="Кредитная карта" GroupName="PaymentMethod" IsChecked="True" Margin="0,0,15,0" FontFamily="{StaticResource SecondaryFont}"/>
				<RadioButton x:Name="rbCash" Content="Наличные" GroupName="PaymentMethod" Margin="0,0,15,0" FontFamily="{StaticResource SecondaryFont}"/>
				<RadioButton x:Name="rbVoucher" Content="Ваучер" GroupName="PaymentMethod" FontFamily="{StaticResource SecondaryFont}"/>
			</StackPanel>

			<CheckBox Grid.Row="4" 
                      x:Name="chkPrintReceipt" 
                      Content="Распечатать чек после оформления" 
                      IsChecked="False" 
                      Margin="0,0,0,20" 
                      FontFamily="{StaticResource SecondaryFont}" 
                      VerticalAlignment="Center"/>

			<StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center">
				<Button x:Name="btnCancel" Content="Отмена" Style="{StaticResource DangerButton}" 
				Click="BtnCancel_Click" Width="100"/>
				<Button x:Name="btnIssueTicket" Content="Готово" Style="{StaticResource PrimaryButton}" 
				Click="BtnIssueTicket_Click" Width="150" Margin="10,0,0,0"/>
			</StackPanel>

			<TextBlock Grid.Row="6" x:Name="txtError" Foreground="#E74C3C" Visibility="Collapsed" Margin="0,10,0,0" TextAlignment="Center"/>
		</Grid>
	</Border>
</Window>
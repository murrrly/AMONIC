<Window x:Class="AMONIC.AddUserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление пользователя" 
        Height="600" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="White">

	<Border Margin="20">
		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
			</Grid.RowDefinitions>

			<!-- Заголовок -->
			<TextBlock Grid.Row="0" 
                       Text="Новый пользователь" 
                       FontSize="18" FontWeight="Bold"
                       FontFamily="{StaticResource PrimaryFont}"
                       Foreground="{StaticResource BrandBlueBrush}"
                       Margin="0,0,0,20"/>

			<!-- Имя -->
			<TextBlock Grid.Row="1" Text="Имя:" VerticalAlignment="Center"/>
			<TextBox Grid.Row="2" x:Name="txtFirstName" Margin="0,5"/>

			<!-- Фамилия -->
			<TextBlock Grid.Row="3" Text="Фамилия:" VerticalAlignment="Center" Margin="0,10,0,0"/>
			<TextBox Grid.Row="4" x:Name="txtLastName" Margin="0,5"/>

			<!-- Email -->
			<TextBlock Grid.Row="5" Text="Email:" VerticalAlignment="Center" Margin="0,10,0,0"/>
			<TextBox Grid.Row="6" x:Name="txtEmail" Margin="0,5"/>

			<!-- Пароль -->
			<TextBlock Grid.Row="7" Text="Пароль:" VerticalAlignment="Center" Margin="0,10,0,0"/>
			<PasswordBox Grid.Row="8" x:Name="txtPassword" Margin="0,5"/>

			<!-- Дата рождения -->
			<TextBlock Grid.Row="9" Text="Дата рождения:" VerticalAlignment="Center" Margin="0,10,0,0"/>
			<DatePicker Grid.Row="10" x:Name="dpBirthdate" Margin="0,5"/>

			<!-- Офис -->
			<TextBlock Grid.Row="11" Text="Офис:" VerticalAlignment="Center" Margin="0,10,0,0"/>
			<ComboBox Grid.Row="12" x:Name="cmbOffice" DisplayMemberPath="Title" SelectedValuePath="ID" Margin="0,5"/>

			<!-- Роль -->
			<TextBlock Grid.Row="13" Text="Роль:" VerticalAlignment="Center" Margin="0,10,0,0"/>
			<ComboBox Grid.Row="14" x:Name="cmbRole" DisplayMemberPath="Title" SelectedValuePath="ID" Margin="0,5"/>

			<!-- Сообщение об ошибке -->
			<TextBlock Grid.Row="15" x:Name="txtError" Foreground="#E74C3C" Visibility="Collapsed" Margin="0,10"/>

			<!-- Кнопки -->
			<StackPanel Grid.Row="16" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
				<Button Content="Отмена" Style="{StaticResource DangerButton}" 
                        Background="#D9534F" Foreground="White" Click="BtnCancel_Click" Width="100"/>
				<Button Content="Сохранить" Style="{StaticResource PrimaryButton}" 
                        Click="BtnSave_Click" Width="100" Margin="10,0,0,0"/>
			</StackPanel>
		</Grid>
	</Border>
</Window>
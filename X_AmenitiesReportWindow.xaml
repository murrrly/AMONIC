<Window x:Class="AMONIC.AmenitiesReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Отчёт по дополнительным услугам"
        Height="500" Width="700"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="Отчёт по дополнительным услугам" 
                   FontSize="22" 
                   FontWeight="Bold"
                   FontFamily="{StaticResource PrimaryFont}"
                   Foreground="{StaticResource DarkBlueBrush}"
                   Margin="0,0,0,20"/>

        <Border Grid.Row="1" 
                Background="White" 
                CornerRadius="5"
                BorderBrush="#DDD" 
                BorderThickness="1"
                Padding="15"
                Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <RadioButton x:Name="rbByDate" Content="По датам" GroupName="ReportType" IsChecked="True" Grid.Row="0" Grid.Column="0" Margin="0,0,20,10" Click="RbByDate_Checked"/>
                <RadioButton x:Name="rbByFlight" Content="По рейсу" GroupName="ReportType" Grid.Row="0" Grid.Column="2" Click="RbByFlight_Checked"/>

                <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal">
                    <DatePicker x:Name="dpDateFrom" Width="120" Margin="0,0,10,0"/>
                    <TextBlock Text="—" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <DatePicker x:Name="dpDateTo" Width="120"/>
                    <Button x:Name="btnSearch" Content="Показать" Style="{StaticResource PrimaryButton}" Click="BtnSearch_Click" Width="100" Margin="10,0,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Horizontal" Visibility="Collapsed" x:Name="panelFlight">
                    <TextBox x:Name="txtFlightNumber" Width="120" FontFamily="{StaticResource SecondaryFont}" ToolTip="Номер рейса"/>
                    <DatePicker x:Name="dpFlightDate" Width="120" Margin="10,0,0,0"/>
                    <Button x:Name="btnSearchFlight" Content="Показать" Style="{StaticResource PrimaryButton}" Click="BtnSearchFlight_Click" Width="100" Margin="10,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <TextBlock Grid.Row="2" x:Name="txtTitle" FontSize="14" FontWeight="Bold" FontFamily="{StaticResource PrimaryFont}" Margin="0,0,0,10"/>

        <DataGrid x:Name="dgReport" 
                  Grid.Row="3"
                  AutoGenerateColumns="True"
                  IsReadOnly="True"
                  RowBackground="White"
                  FontFamily="{StaticResource SecondaryFont}"
                  BorderBrush="#DDD"
                  RowHeight="35"/>
    </Grid>
</Window>